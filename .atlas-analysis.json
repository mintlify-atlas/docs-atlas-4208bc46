  "keyFeatures": [
    "Real-time synchronized lyrics display",
    "Custom song format with timing and reading hints",
    "OpenGL-based rendering with animations and effects",
    "Audio playback with MP3 support via OpenAL",
    "WebAssembly support for browser deployment",
    "Customizable UI with gradient backgrounds and themes",
    "Font override support for multiple writing systems",
    "Dynamic fill and pulse effects for active lyrics",
    "Album art display with shadows and effects",
    "Menu mode for song selection"
  ],
  "publicApiSurface": [
    "global_init() - Initialize application",
    "global_finish() - Clean up resources",
    "global_mode_switch() - Switch between karaoke/menu modes",
    "karaoke_init() - Initialize karaoke mode",
    "karaoke_loop() - Main karaoke loop",
    "ui_init() - Initialize UI system",
    "ui_make_text() - Create text drawable",
    "ui_make_image() - Create image drawable",
    "ui_make_container() - Create UI container",
    "ui_animate_* - Animation functions",
    "audio_init() - Initialize audio system",
    "audio_load() - Load audio file",
    "audio_resume() - Resume playback",
    "audio_pause() - Pause playback",
    "audio_seek() - Seek to position",
    "song_load() - Parse song file",
    "song_get() - Get current song",
    "config_get() - Get configuration"
  ]
